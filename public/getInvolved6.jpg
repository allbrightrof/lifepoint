        :root {
            
    
        --body-font-family: "Christmas 205", sans-serif;
        --body-font-weight: 100;
    

        
            --heading-font-family: "helvetica neue", sans-serif;
            --heading-font-weight: 700;
        




        --base-color-bg-dark: #cccccc;
        --base-color-bg: #ffffff;
        --base-color-bg-light: #ffffff;
        --base-color-text: #000000;
        --alt-color-bg-dark: #c4c4c4;
        --alt-color-bg: #f4f4f4;
        --alt-color-bg-light: #f7f7f7;
        --alt-color-text: #000000;
        --primary-color-bg-dark: #717171;
        --primary-color-bg: #8D8D8D;
        --primary-color-bg-light: #a4a4a4;
        --primary-color-text: #ffffff;
        --secondary-color-bg-dark: #cccccc;
        --secondary-color-bg: #ffffff;
        --secondary-color-bg-light: #ffffff;
        --secondary-color-text: #ffffff;
        --tertiary-color-bg-dark: #000000;
        --tertiary-color-bg: #000000;
        --tertiary-color-bg-light: #333333;
        --tertiary-color-text: #ffffff;
        --currentcolor-color-bg-dark: currentColor;
        --currentcolor-color-bg: currentColor;
        --currentcolor-color-bg-light: currentColor;
        --currentcolor-color-text: currentColor;
        --transparent-color-bg-dark: transparent;
        --transparent-color-bg: transparent;
        --transparent-color-bg-light: transparent;
        --transparent-color-text: transparent;
    
            
         
         --theme-element-padding-vertical: 0.625rem;
         --theme-element-padding-horizontal: 0.875rem;
         
         --theme-container-width: 1145px;
         --theme-small-container-width: 800px;
         --theme-gutter: 1em;
         --theme-heading-one-font-size: 3.5rem;
         --theme-heading-two-font-size: 3rem;
         --theme-heading-three-font-size: 2.5rem;
         --theme-heading-four-font-size: 2rem;
         --theme-heading-five-font-size: 1.5rem;
         --theme-heading-six-font-size: 1rem;
         --theme-spacer: 2rem;

         /** New Theming Starts Here **/
         --theme-hero-padding-top: 6em;
         --theme-hero-padding-left: 0em;
         --theme-hero-padding-right: 0em;
         --theme-hero-padding-bottom: 6em;
         --theme-hero-padding-top-mobile: 8em;
         --theme-hero-padding-left-mobile: 0em;
         --theme-hero-padding-right-mobile: 0em;
         --theme-hero-padding-bottom-mobile: 4em;
         --theme-hero-text-align: center;
         --theme-hero-justify: center;

         --theme-row-padding-top: 4em;
         --theme-row-padding-left: 0em;
         --theme-row-padding-right: 0em;
         --theme-row-padding-bottom: 4em;
         --theme-row-padding-top-mobile: 2em;
         --theme-row-padding-left-mobile: 0em;
         --theme-row-padding-right-mobile: 0em;
         --theme-row-padding-bottom-mobile: 2em;
         

         --theme-row-width: 100%;
         --theme-row-margin-horizontal: 0em;
         --theme-row-margin-vertical: 0em;
         --theme-row-text-align: center;
         --theme-row-justify: center;

         --theme-border-radius: 0px;
         --theme-border-radius-md: 0px;
         --theme-border-radius-sm: 0px;

         --theme-row-border-radius: 0px;
         --theme-row-border-radius-md: 0px;
         --theme-row-border-radius-sm: 0px;
         

         /* TODO: Calculate Large,Medium,Small Shasow */
         --theme-shadow: 0px 0px 0px 0px rgba(0,0,0,0.17);
         --theme-shadow-lg: 0px 0px 0px 0px rgba(0,0,0,0.17);
         --theme-shadow-md: 0px 0px 0px 0px rgba(0,0,0,0.17);
         --theme-shadow-sm: 0px 0px 0px 0px rgba(0,0,0,0.17);
        
         /* Buttons */
         --theme-button-padding-top: 1rem;
         --theme-button-padding-bottom: 1rem;
         --theme-button-padding-left: 1.75rem;
         --theme-button-padding-right: 1.75rem;
         --theme-button-radius: 100px;


         /* Form Inputs */
         --theme-input-border-radius: 0px;
         --theme-input-shadow: 0px 0px 0px 4px currentColor;
         --theme-input-border: 0px solid rgba(0,0,0,0.15);
    
        }
        

    [data-website] .header-defaults h1 {
        font-size: clamp(2rem,6.5vw,7rem);
    }
    [data-website] .header-defaults h2 {
        font-size: clamp(2rem,3vw,5rem);
    }
    [data-website] .header-defaults p {
        font-size: 1.5em;
    }
    html [data-website] {
        font-size: 18px;
    }
    .row-defaults h3 {
        font-size: 3rem;
    }
    [data-website] .rich-wrap {
        gap: 1.5rem !important;
    }

    
    
    [data-website] .accordion-wrap .accordion-title {

		transform: scale3d(1, 1, 1);
        transition: all 500ms cubic-bezier(.33, 0, .19, 1);
        font-size: 1.25rem;
        position: relative
    }
    [data-website] .accordion-wrap.-theme-default .accordion-title {
        padding-left: 0;
        padding-right: 0;
    }
    [data-website] .accordion-wrap.-theme-default .accordion-title:after {
        content: "";
        position: absolute;
        top: -3px;
        left: 0;
        width: 100%;
        height: 4px;
        background-color: currentColor;
        opacity: 1;
    }
    [data-website] .accordion-wrap .trigger:before,
    [data-website] .accordion-wrap .trigger:after {
        height: 0.25em;
        width: 1.2em;
    }

    .notification-wrap .announcement {
        border: 4px solid currentColor !important;
   }
    @container(max-width:768px){
        [data-website] .header-defaults h1 {
            font-size: clamp(2rem,4.5vw,6rem);
        }
        [data-website] .header-defaults h2 {
            font-size: clamp(2rem,2vw,4rem);
        }
    }
    
    



        
    
            
            body [data-website] { 
                font-family: "Christmas 205", sans-serif;
font-weight: 100;

                background-color: #ffffff;
                color: #000000;
                container-type: inline-size;
                height: 100%;
                position: relative;
            }

            
                [data-website] h1, [data-website] .h1 { font-size: 4rem;
font-family: "helvetica neue", sans-serif;
font-weight: 700;
 }
                [data-website] h2, [data-website] .h2 { font-size: 3rem;
font-family: "helvetica neue", sans-serif;
font-weight: 700;
 }
                [data-website] h3, [data-website] .h3 { font-size: 1.8rem;
font-family: "helvetica neue", sans-serif;
font-weight: 700;
 }
                [data-website] h4, [data-website] .h4 { font-family: "helvetica neue", sans-serif;
font-weight: 700;
 }
                [data-website] h5, [data-website] .h5 { font-family: "helvetica neue", sans-serif;
font-weight: 400;
 }
                [data-website] h6, [data-website] .h6 { font-family: "helvetica neue", sans-serif;
font-weight: 700;
 }
                [data-website] ul { font-family: "helvetica neue", sans-serif;
font-weight: 400;
list-style-type: disc;
 }
