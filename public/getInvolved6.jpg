                }
            
            
            /** Color Helpers **/
            /*
            [data-website] .color-base { background-color: var(--base-color-bg); color: var(--base-color-text); }
            [data-website] .color-alt { background-color: var(--alt-color-bg); color: var(--alt-color-text); }
            [data-website] .color-primary { background-color: var(--primary-color-bg); color: var(--primary-color-text); }
            [data-website] .color-secondary { background-color: var(--secondary-color-bg); color: var(--secondary-color-text); }
            [data-website] .color-tertiary { background-color: var(--tertiary-color-bg); color: var(--tertiary-color-text); }
            */
            
            [data-website] .rich-wrap {
                display: flex;
                flex-direction: column;
                gap: 1rem;
            }
            [data-website] .rich-wrap img,
            [data-website] .rich-wrap iframe,
            [data-website] iframe,
            [data-website] [xdata-audio-player],
            [data-website] [data-slideshow] img,
            [data-website] .feature-image,
            [data-website] .feature youtube-video,
            [data-website] .feature vimeo-video {
                box-shadow: var(--theme-shadow-md);
                border-radius: var(--theme-border-radius);
            }
            [data-website] .rich-wrap .StripeElement iframe,
            [data-website] .StripeElement iframe {
                box-shadow: none;
                border-radius: 0px;

            }
            [data-website] table {
                width: 100%;
            }

            @container (max-width:768px){
                [data-website] .dragger.tcc-w-full,
                [data-website] .dragger.tcc-w-half,
                [data-website] .dragger.tcc-w-third,
                [data-website] .dragger.tcc-w-fill {
                    width: 100% !important;
                }
            }

            @media(min-width: 768px){
    .topbar.transparent{
        width: var(--theme-container-width);
        margin: 2em auto;
        border-bottom: 1px solid;
        left: 50%;
        transform: translatex(-50%);
    }

    .topbar.transparent + #blocks header{
        padding-top: 12em!important;
    }

    .custom-episode .container{
        display: flex;
        flex-direction: row;
        align-items: center;
    }

    .custom-episode .container > div{
        margin: 0px;
    }

    .custom-episode .row-defaults *:not([data-buttons]){
        width: 100%!important;
    }

    .custom-episode .row-content{
        padding-left: 2em;
                flex: 1;
    }

    .custom-episode .row-defaults{
        width: 40%;
    }

    .image-full-width .container{
        max-width: 100%;
    }

    .image-full-width .row-inner{
        padding-top: 1rem;
        padding-bottom: 0px;
    }

    .custom-bg{
        position: relative;
    }

    .custom-bg::before{
        content: "";
        background-image: url("https://media.thechurchcoassets.com/accounts/3084/be42f117-8500-44fd-8c3b-313f14f254b9-./Life%20Point%20Bg.jpg");
        background-size: 120%;
        background-position: center;
        display: block;
        position: absolute;
        top: 0px;
        bottom: 0px;
        left: 0px;
        right: 0px;
        opacity: 0.05;
    }
}

.custom-marquee [data-marquee]{
    padding-top: 2em;
    padding-bottom: 2em;
}

.custom-marquee + .block-marquee .text-container{
    animation-direction: reverse;
}

.custom-episode .card .content *{
    display: none;
}

.custom-episode .card .content{
    margin-top: 0px;
}

.custom-episode .card{
    padding: 0px;
}

.custom-episode .card::before,
.custom-episode .card::after,
.custom-episode .card .content::before,
.custom-episode .card .content::after{
    content: none;
}

.custom-columns [data-listitem]{
    background-color: var(--base-color-bg);
    color: var(--base-color-text);
    box-shadow: 0px 0px 20px rgba(0,0,0, 0.1);
    border-radius: 10px;
}

.custom-columns [data-listitem] .content{
    padding: 1em 2em;
}

.custom-icons [data-listitem]{
    background-color: var(--base-color-bg);
    color: var(--base-color-text);
    box-shadow: 0px 0px 20px rgba(0,0,0, 0.1);
    padding: 2em;
    border-radius: 10px;
}

.custom-icons [data-listitem] .feature.icon [data-themed-icon]{
    background-color: var(--primary-color-bg);
    color: var(--primary-color-text);
    width: 2em;
    height: 2em;
    border-radius: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.2em;
}

.custom-marquee [data-marquee]{
    overflow: hidden!important;
}

@media(min-width: 768px){
    .fix-featured .card:first-child{
        gap: 1rem;
    }
}

footer a{
    text-decoration: none!important;
}
.chicago {font-family: "Chicago", Serif !important;
	font-weight: 400 !important;
	font-style: normal !important;}
            
